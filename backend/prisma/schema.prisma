generator client {
  provider = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "windows", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ToggleMode {
  AI_FULL
  AI_ASK
  HUMAN_ONLY
}

enum ConversationStatus {
  AI_ACTIVE
  HUMAN_REQUIRED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  DRAFT_TO_APPROVE
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  PAUSED
  EXPIRED
}

model SuperAdmin {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

model Business {
  id                    String                @id @default(cuid())
  name                  String
  email                 String?               @unique
  whatsappPhoneNumberId String                @unique
  whatsappBusinessNumber String?
  metaAppId             String?
  apiKey                String                @unique @default(cuid())
  customSystemPrompt    String?               @db.Text
  subscriptionStatus    SubscriptionStatus    @default(ACTIVE)
  isPaused              Boolean               @default(false)
  aiTrainingData        Json?
  admins                BusinessAdmin[]
  controlToggles        ControlToggles?
  customers             Customer[]
  conversations         Conversation[]
  products              Product[]
  platformMetrics       PlatformMetric[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([name, subscriptionStatus])
}

model BusinessAdmin {
  id         String   @id @default(cuid())
  businessId String
  email      String
  passwordHash String
  name       String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, email])
  @@index([businessId])
}

model ControlToggles {
  id                         String      @id @default(cuid())
  businessId                 String      @unique
  togglePaymentDetails       ToggleMode  @default(AI_ASK)
  togglePriceQuotes          ToggleMode  @default(AI_ASK)
  toggleBookingConfirmation  ToggleMode  @default(AI_ASK)
  toggleFirstCustomerMessage ToggleMode  @default(AI_ASK)
  business                   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  updatedBy                  String?
  updatedAt                  DateTime    @updatedAt

  @@index([businessId])
}

model Customer {
  id            String          @id @default(cuid())
  businessId    String
  waId          String
  name          String?
  phoneNumber   String?
  conversations Conversation[]
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([businessId, waId])
  @@index([businessId, waId])
}

model Conversation {
  id             String             @id @default(cuid())
  businessId     String
  customerId     String
  status         ConversationStatus @default(AI_ACTIVE)
  humanReason    String?
  rejectedDrafts Int                @default(0)
  lastMessageAt  DateTime           @default(now())
  followUpSentAt DateTime?
  followUpCount  Int                @default(0)
  messages       Message[]
  business       Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([businessId, customerId])
  @@index([status, lastMessageAt])
  @@index([businessId, customerId])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  body           String           @db.VarChar(2000)
  metaMessageId  String?          @unique
  needsApproval  Boolean          @default(false)
  approvalSeenAt DateTime?
  rejectionReason String?
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model PlatformMetric {
  id              String   @id @default(cuid())
  businessId      String
  groqRequestsCount Int     @default(0)
  metaWebhooksCount Int     @default(0)
  averageReplyTime Float   @default(0)
  messagesProcessed Int    @default(0)
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([businessId])
  @@index([businessId])
}

model Product {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  sku         String?
  description String?  @db.Text
  category    String?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("NGN") @db.VarChar(8)
  isActive    Boolean  @default(true)
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, isActive])
  @@index([businessId, category])
  @@unique([businessId, name])
  @@unique([businessId, sku])
}

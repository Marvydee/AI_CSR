    {
      "name": "02 - Auth",
      "item": [
        {
          "name": "POST /api/auth/admin/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('ACCESS_TOKEN', json.accessToken);",
                  "pm.environment.set('BUSINESS_ID', json.user.businessId);",
                  "pm.test('token and business id captured', function () {",
                  "  pm.expect(pm.environment.get('ACCESS_TOKEN')).to.be.a('string');",
                  "  pm.expect(pm.environment.get('BUSINESS_ID')).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ADMIN_EMAIL}}\",\n  \"password\": \"{{ADMIN_PASSWORD}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/admin/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "admin", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "03 - Webhook",
      "item": [
        {
          "name": "GET /webhook verify success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('verify status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('challenge echoed', function () {",
                  "  pm.expect(pm.response.text()).to.eql('12345');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/webhook?hub.mode=subscribe&hub.verify_token={{WHATSAPP_VERIFY_TOKEN}}&hub.challenge=12345",
              "host": ["{{BASE_URL}}"],
              "path": ["webhook"],
              "query": [
                {
                  "key": "hub.mode",
                  "value": "subscribe"
                },
                {
                  "key": "hub.verify_token",
                  "value": "{{WHATSAPP_VERIFY_TOKEN}}"
                },
                {
                  "key": "hub.challenge",
                  "value": "12345"
                }
              ]
            }
          }
        },
        {
          "name": "GET /webhook verify failure",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('verify failure is 403', function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/webhook?hub.mode=subscribe&hub.verify_token=wrong-token&hub.challenge=12345",
              "host": ["{{BASE_URL}}"],
              "path": ["webhook"],
              "query": [
                {
                  "key": "hub.mode",
                  "value": "subscribe"
                },
                {
                  "key": "hub.verify_token",
                  "value": "wrong-token"
                },
                {
                  "key": "hub.challenge",
                  "value": "12345"
                }
              ]
            }
          }
        },
        {
          "name": "POST /webhook inbound pricing message",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const secret = pm.environment.get('META_APP_SECRET') || '';",
                  "const rawBody = pm.request.body ? (pm.request.body.raw || '') : '';",
                  "const hash = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Hub-Signature-256', value: `sha256=${hash}` });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('webhook accepted', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entry\": [\n    {\n      \"changes\": [\n        {\n          \"value\": {\n            \"metadata\": {\n              \"phone_number_id\": \"{{WHATSAPP_PHONE_NUMBER_ID}}\"\n            },\n            \"contacts\": [\n              {\n                \"wa_id\": \"{{CUSTOMER_WA_ID}}\",\n                \"profile\": {\n                  \"name\": \"John Tester\"\n                }\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"{{CUSTOMER_WA_ID}}\",\n                \"id\": \"wamid.TEST.001\",\n                \"text\": {\n                  \"body\": \"Hi, how much is your premium package?\"\n                }\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/webhook",
              "host": ["{{BASE_URL}}"],
              "path": ["webhook"]
            }
          }
        },
